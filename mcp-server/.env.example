# Production MCP Server — Credential Configuration
# Copy to .env.production-mcp (gitignored) and fill in real values.

# Redis
# REDIS_URL=redis://production-redis:6379/0

# Postgres
# POSTGRES_URL=postgresql://user:pass@production-postgres:5432/dbname

# OpenSearch
# OPENSEARCH_URL=https://production-opensearch:9200
# OPENSEARCH_USER=admin
# OPENSEARCH_PASSWORD=

# S3
# S3_BUCKET=production-logs
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
