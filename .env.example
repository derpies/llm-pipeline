ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# LLM config
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514

# Embeddings
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=

# Postgres (used by docker-compose)
POSTGRES_USER=llm_pipeline
POSTGRES_PASSWORD=llm_pipeline
POSTGRES_DB=llm_pipeline
DATABASE_URL=postgresql://llm_pipeline:llm_pipeline@postgres:5432/llm_pipeline

# Redis
REDIS_URL=redis://redis:6379/0

# Email Analytics
EMAIL_BATCH_SIZE=10000
EMAIL_TIME_WINDOW_HOURS=1
EMAIL_LOOKBACK_DAYS=30
EMAIL_ANOMALY_THRESHOLD=3.5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=dev
LOG_DIR=output/logs

# LangSmith (optional — enables automatic tracing of all LLM/tool/graph calls)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv_...
# LANGCHAIN_PROJECT=llm-pipeline

# Host-mapped ports (for reference, not used by app inside container):
# App (FastAPI): localhost:20000
# Postgres:      localhost:20001
# Redis:         localhost:20002
